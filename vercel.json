{
  "redirects": [
    {
      "source": "/openapi.json",
      "destination": "/api/openapi.json",
      "permanent": false
    },
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "mpp.tempo.xyz" }],
      "destination": "https://mpp.dev/:path",
      "permanent": true
    }
  ]
}
