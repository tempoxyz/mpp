{
  "version": "0.2",
  "language": "en",
  "files": ["src/pages/**/*.mdx", "src/pages/**/*.md"],
  "ignorePaths": ["node_modules", "dist", ".vocs", "pnpm-lock.yaml"],
  "dictionaries": ["typescript", "node", "npm", "software-terms"],
  "overrides": [
    {
      "filename": "**/*.mdx",
      "languageId": "mdx"
    }
  ],
  "ignoreRegExpList": [
    "Base64MultiLine",
    "Base64SingleLine",
    "Email",
    "SHA",
    "Urls",
    "UnicodeRef",
    "CStyleHexValue",
    "/0x[0-9a-fA-F]{4,}/g",
    "/`[^`]*`/g",
    "/eyJ[A-Za-z0-9+/=]+/g"
  ],
  "flagWords": ["crypto"],
  "words": [
    "aiter",
    "asyncio",
    "bottlenecked",
    "bunx",
    "elysia",
    "fastapi",
    "httpauth",
    "httpx",
    "isinstance",
    "kwargs",
    "llms",
    "micropayments",
    "modelcontextprotocol",
    "mppx",
    "offchain",
    "paymentauth",
    "permissionless",
    "picsum",
    "polyfilling",
    "preimage",
    "pympp",
    "reqwest",
    "serde",
    "stablecoins",
    "tempoxyz",
    "twoslash",
    "viem",
    "vocs",
    "wagmi",
    "wevm"
  ]
}
