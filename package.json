    "viem": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@standard-schema/spec": "^1.1.0",
    "ox": "^0.11.3"
  },
  "sideEffects": false,
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts"
