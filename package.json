{
  "name": "docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-discovery.ts && node scripts/build-diagrams.ts && node scripts/copy-vocs-theme.ts && node scripts/generate-cli-help.ts && node scripts/generate-og-descriptions.ts && vite build",
    "check": "biome check --write",
    "check:ci": "biome check",
    "check:sdk-drift": "npx tsx .github/actions/sdk-drift-check/check-sdk-drift.ts",
    "check:types": "tsc --noEmit",
    "dev": "node scripts/generate-discovery.ts && vite dev",
    "generate:discovery": "node scripts/generate-discovery.ts",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "preview": "vite preview",
    "sync:vocs": "node scripts/copy-vocs-theme.ts && pnpm check",
    "test": "vitest run",
    "test:e2e": "VITE_SKIP_ANIMATION=true VITE_DEMO_LIVE=false vitest run --config vitest.config.e2e.ts",
    "test:watch": "viest"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@resvg/resvg-wasm": "^2.6.2",
    "@stripe/stripe-js": "^9.3.1",
    "@vercel/blob": "^2.3.3",
    "mermaid": "^11.14.0",
    "mppx": "0.6.5",
    "react": "^19",
    "react-dom": "^19",
    "stripe": "^22.1.0",
    "tailwindcss": "^4.2.4",
    "viem": "^2.48.4",
    "vocs": "https://pkg.pr.new/vocs@425",
    "wagmi": "^3.6.5",
    "waku": "^1.0.0-alpha.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@iconify/json": "^2.2.467",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^6",
    "ajv": "8",
    "ajv-formats": "^3.0.1",
    "happy-dom": "^20.9.0",
    "playwright": "^1.59.1",
    "shiki": "4.0.2",
    "simple-git-hooks": "^2.13.1",
    "tiktoken": "^1.0.22",
    "typescript": "^6",
    "unplugin-icons": "^23.0.1",
    "vite": "^8.0.10",
    "vite-plugin-mkcert": "^2.0.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "patchedDependencies": {
      "vocs@0.0.0": "patches/vocs@0.0.0.patch"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  }
}
