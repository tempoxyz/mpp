{
  "name": "docs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "node scripts/generate-discovery.ts && node scripts/build-diagrams.ts && node scripts/copy-vocs-theme.ts && node scripts/generate-cli-help.ts && vite build",
    "check": "biome check --write",
    "check:sdk-drift": "npx tsx .github/actions/sdk-drift-check/check-sdk-drift.ts",
    "check:types": "tsc --noEmit",
    "dev": "vite dev",
    "preinstall": "pnpx only-allow pnpm",
    "prepare": "pnpm simple-git-hooks",
    "preview": "vite preview",
    "sync:vocs": "node scripts/copy-vocs-theme.ts && pnpm check",
    "test": "vitest run",
    "test:watch": "viest"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@fontsource/commit-mono": "^5.2.5",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-store": "^0.8.0",
    "class-variance-authority": "^0.7.1",
    "mermaid": "^11.12.2",
    "mppx": "~0.3.5",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4.1.18",
    "viem": "^2.46.2",
    "vocs": "https://pkg.pr.new/wevm/vocs@6641be0",
    "wagmi": "^3.4.2",
    "waku": "^1.0.0-alpha.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@iconify/json": "^2.2.433",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "ajv": "8",
    "ajv-formats": "^3.0.1",
    "simple-git-hooks": "^2.13.1",
    "tiktoken": "^1.0.22",
    "typescript": "^5",
    "unplugin-icons": "^23.0.1",
    "vite": "^7",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.22.0",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.5.1",
      "onFail": "download"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  }
}
